{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "model": "gitlab/duo-chat",
  "small_model": "gitlab/duo-chat-haiku-4-5",
  "share": "disabled",
  "autoupdate": true,
  "server": {
    "hostname": "127.0.0.1",
    "mdns": false
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "skill": "allow",

    "bash": {
      "find *": "ask",
      "git commit*": "ask",
      "git commit *": "ask",
      "git push*": "ask",
      "git push *": "ask",
      "rm -rf *": "deny",
      "curl *": "deny",
      "wget *": "deny"
    },

    "external_directory": "ask",
    "doom_loop": "ask",
    "~/.aws/*": "deny",
    "~/.gnupg/*": "deny",
    "~/.netrc": "deny",
    "~/.ssh/*": "deny"
  },
  "plugin": [
    "opencode-skills",
    "@gitlab/opencode-gitlab-plugin",
    "@gitlab/opencode-gitlab-auth",
    "opencode-agent-memory@0.2.0",
    "opencode-mermaid-formatter",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "provider": {
    "gitlab": {
      "options": {
        "instanceUrl": "https://gitlab.com",
        "featureFlags": {
          "duo_agent_platform_agentic_chat": true,
          "duo_agent_platform": true
        }
      },
      "models": {
        "duo-chat-haiku-4-5": {
          "cost": {
            "input": 0.8,
            "output": 4
          }
        },
        "duo-chat-sonnet-4-5": {
          "cost": {
            "input": 3,
            "output": 15
          }
        },
        "duo-chat-opus-4-5": {
          "cost": {
            "input": 15,
            "output": 75
          }
        },
        "duo-chat-haiku-4-6": {
          "cost": {
            "input": 0.8,
            "output": 4
          }
        },
        "duo-chat-sonnet-4-6": {
          "cost": {
            "input": 3,
            "output": 15
          }
        },
        "duo-chat-opus-4-6": {
          "cost": {
            "input": 15,
            "output": 75
          }
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://192.168.50.70:11434/v1"
      },
      "models": {
        "gemma4:latest": { "name": "gemma4:latest" },
        "qwen3-coder:latest": { "name": "qwen3-coder:latest" },
        "devstral:latest": { "name": "devstral:latest" },
        "mychen76/qwen3_cline_roocode:30b": { "name": "mychen76/qwen3_cline_roocode:30b" },
        "deepseek-r1:32b": { "name": "deepseek-r1:32b" },
        "deepseek-v2:16b": { "name": "deepseek-v2:16b" }
      }
    }
  },
  "mcp": {
    "lazy-mcp": {
      "type": "local",
      "command": ["lazy-mcp", "--config", "/Users/skarbek/.config/lazy-mcp/servers.json"],
      "enabled": true
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "edit": {
          "*": "ask",
          "~/projects/scratchpad/*.md": "allow"
        },
        "external_directory": {
          "~/projects/scratchpad/**": "allow"
        }
      }
    }
  }
}
